DATASETAUXDATA BasicAlgorithm = "Lattice Boltzmann Method (LBM)"
DATASETAUXDATA TurbulenceModel = "LBM-VLES, k-e-based, adapted to LBM"
DATASETAUXDATA GridId = "Cartesian (Custom)"
DATASETAUXDATA Notes = ""

